    {
      "parameters": {
        "jsCode": "// spec: §Condiciones — Motor de reglas (precedencia estricta)\n// blacklist > whitelist > anónimo > prefijo > horario > default answer\n\nconst rules = $input.all().map(i => i.json);\nconst callFields = $('Extract Call Fields').first().json;\nconst phoneRow = $('Resolve Owner (phone_numbers)').first().json;\n\nconst callerNumber = callFields.from; // null if anonymous\nconst calledAt = new Date(); // UTC now\n\n// Helper: convert UTC time to user timezone and extract HH:MM\nfunction localHHMM(tz) {\n  const str = calledAt.toLocaleTimeString('en-US', { hour12: false, timeZone: tz, hour: '2-digit', minute: '2-digit' });\n  const [h, m] = str.split(':').map(Number);\n  return h * 60 + m; // minutes since midnight\n}\n\n// Helper: does a time range [start HH:MM, end HH:MM] cover minutesSinceMidnight?\n// Handles ranges that cross midnight (e.g. 22:00-06:00)\nfunction inSchedule(start, end, nowMins) {\n  const [sh, sm] = start.split(':').map(Number);\n  const [eh, em] = end.split(':').map(Number);\n  const s = sh * 60 + sm;\n  const e = eh * 60 + em;\n  if (s <= e) return nowMins >= s && nowMins < e;       // normal range\n  return nowMins >= s || nowMins < e;                  // crosses midnight\n}\n\n// User timezone from phone_numbers row (fall back to El Salvador if missing)\nconst userTZ = phoneRow.user_timezone || 'America/El_Salvador';\nconst nowLocal = localHHMM(userTZ);\n\nlet decision = 'answer';\nlet rejectAction = null;\nlet matchedRule = 'default';\n\n// 1. Blacklist\nif (callerNumber) {\n  const bl = rules.find(r => r.rule_type === 'blacklist' && r.value?.number === callerNumber);\n  if (bl) { decision = 'reject'; rejectAction = 'busy'; matchedRule = bl.id; }\n}\n\n// 2. Whitelist (only if not already rejected)\nif (decision === 'answer' && callerNumber) {\n  const wl = rules.find(r => r.rule_type === 'whitelist' && r.value?.number === callerNumber);\n  if (wl) { decision = 'answer'; matchedRule = wl.id; }\n}\n\n// 3. Anonymous\nif (decision === 'answer' && !callerNumber) {\n  const anon = rules.find(r => r.rule_type === 'anonymous');\n  if (anon && anon.value?.action === 'reject') {\n    decision = 'reject'; rejectAction = 'message'; matchedRule = anon.id;\n  }\n}\n\n// 4. Prefix block\nif (decision === 'answer' && callerNumber) {\n  const pfx = rules.find(r => r.rule_type === 'prefix_block' && callerNumber.startsWith(r.value?.prefix));\n  if (pfx) { decision = 'reject'; rejectAction = 'busy'; matchedRule = pfx.id; }\n}\n\n// 5. Schedule\nif (decision === 'answer') {\n  const sched = rules.find(r => r.rule_type === 'schedule');\n  if (sched) {\n    const inside = inSchedule(sched.value.start, sched.value.end, nowLocal);\n    if (!inside) { decision = 'reject'; rejectAction = 'message'; matchedRule = sched.id; }\n  }\n}\n\n// 6. Default: answer\n\nreturn [{\n  json: {\n    decision,\n    rejectAction,\n    matchedRule,\n    userId: phoneRow.user_id,\n    phoneNumberId: phoneRow.id,\n    callSid: callFields.callSid,\n    callerNumber,\n    to: callFields.to\n  }\n}];"
      },
