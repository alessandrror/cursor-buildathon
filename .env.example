# =============================================================================
# AI Call Assistant — Variables de entorno
# =============================================================================
# Copia este archivo a .env.local y completa los valores:
#   bun run env:setup
#
# =============================================================================

# --- Clerk (requerido) ---
# Dashboard: https://dashboard.clerk.com → tu app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rutas de autenticación
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Webhook para sincronizar usuarios con Supabase (solo servidor)
# Dashboard: https://dashboard.clerk.com → Webhooks → Add endpoint
# URL del endpoint: https://tu-dominio.com/api/webhooks/clerk
# Eventos: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase (requerido para persistencia) ---
# Conexión directa a PostgreSQL (para migraciones: bun run db:migrate)
# Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
#
#
# 1. Crea un proyecto en https://supabase.com/dashboard
# 2. Project URL:
#    Dashboard → Project Settings → Data API → Project URL
#    (ej: https://abcdefgh.supabase.co — sin /rest/v1 al final)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
#
# 3. Publishable key (anon/public):
#    Dashboard → Project Settings → API Keys → Publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# Alias aceptado por compatibilidad:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# 4. Service role key (solo servidor — nunca expongas en el cliente):
#    Dashboard → Project Settings → API Keys → Secret keys → service_role
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
#
# 5. Database URL (para migraciones con `bun run db:migrate`):
#    Dashboard → Connect → Session pooler → URI (recomendado, IPv4)
#    O usa Direct connection y el script convertirá a Session pooler automáticamente.
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
#
# Opcional: pegar el URI del Session pooler tal cual (tiene prioridad sobre DATABASE_URL)
# DATABASE_POOLER_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# Opcional: región del pooler si la conversión automática falla (ej. us-east-1, eu-west-1)
# SUPABASE_DB_REGION=us-east-1
#
# 5. Integración Clerk ↔ Supabase (obligatorio para RLS):
#    a) Clerk: https://dashboard.clerk.com/setup/supabase → Activate
#    b) Supabase: Authentication → Sign In / Providers → Add Clerk
#       Pega el Clerk domain que te da el paso anterior
#    c) Ejecuta supabase/migrations/*.sql en SQL Editor (001 + 003)

# --- Pipeline de llamadas (credenciales en n8n, no en Next.js) ---
# Ver integrations/n8n/README.md

# Twilio (n8n — validación X-Twilio-Signature)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ElevenLabs (n8n + dashboard de agentes)
# ELEVENLABS_API_KEY=
# ELEVENLABS_WEBHOOK_SECRET=
# ELEVENLABS_AGENT_WSS_URL=wss://api.elevenlabs.io/v1/convai/conversation

# OpenAI / ChatGPT (n8n — generación de resúmenes, model gpt-4o)
# OPENAI_API_KEY=

# n8n Cloud (orquestación de workflows — configurar en n8n, no en Next.js)
# N8N_WEBHOOK_URL=https://your-org.app.n8n.cloud
# N8N_API_KEY=

# --- Desarrollo local ---
# Dashboard con datos de ejemplo (true) vs Supabase real (false)
USE_MOCK_CALLS=true

# Protege POST /api/dev/simulate-call (solo NODE_ENV=development)
# DEV_API_KEY=dev-local-secret
