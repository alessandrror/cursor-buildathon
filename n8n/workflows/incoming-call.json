    {
      "parameters": {
        "jsCode": "// spec: §Autenticación — Validar X-Twilio-Signature (HMAC-SHA1)\n// https://www.twilio.com/docs/usage/security\nconst crypto = require('crypto');\n\nconst authToken = $env['TWILIO_AUTH_TOKEN'];\nconst twilioSig = $input.first().headers['x-twilio-signature'] ?? '';\n\n// Build validation URL: the full public webhook URL\nconst webhookUrl = $env['N8N_WEBHOOK_URL'] + '/webhook/twilio/incoming-call';\n\n// Sort form params alphabetically and concatenate key+value\nconst body = $input.first().body;\nconst sortedKeys = Object.keys(body).sort();\nlet validationStr = webhookUrl;\nfor (const key of sortedKeys) {\n  validationStr += key + body[key];\n}\n\nconst expected = crypto\n  .createHmac('sha1', authToken)\n  .update(Buffer.from(validationStr, 'utf-8'))\n  .digest('base64');\n\nconst valid = expected === twilioSig;\nreturn [{ json: { valid, body } }];"
      },
      "id": "validate-signature",
      "name": "Validate Twilio Signature",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
