    {
      "parameters": {
        "jsCode": "// Build Twilio Basic auth header and parse request params\nconst sid = $env['TWILIO_ACCOUNT_SID'];\nconst token = $env['TWILIO_AUTH_TOKEN'];\nconst auth = 'Basic ' + Buffer.from(`${sid}:${token}`).toString('base64');\n\nconst body = $input.first().body;\nconst parsed = typeof body === 'object' ? body : (JSON.parse(body) || {});\nconst isoCountry = parsed.isoCountry || 'US';\nconst areaCode = parsed.areaCode || null;\n\nreturn [{ json: { auth, accountSid: sid, isoCountry, areaCode, userId: $('Validate JWT').first().json.userId } }];"
      },
