    {
      "parameters": {
        "jsCode": "// spec: §Notas técnicas — verificar JWT Clerk (RS256) con JWKS\nconst { createPublicKey, createVerify } = require('crypto');\n\nconst authHeader = $input.first().headers['authorization'] ?? '';\nconst jwt = authHeader.replace(/^Bearer\\s+/i, '').trim();\nif (!jwt) return [{ json: { valid: false, reason: 'missing_token' } }];\n\nconst parts = jwt.split('.');\nif (parts.length !== 3) return [{ json: { valid: false, reason: 'malformed_token' } }];\nconst [headerB64, payloadB64, sigB64] = parts;\n\nlet header, payload;\ntry {\n  header = JSON.parse(Buffer.from(headerB64, 'base64url').toString());\n  payload = JSON.parse(Buffer.from(payloadB64, 'base64url').toString());\n} catch (e) {\n  return [{ json: { valid: false, reason: 'parse_error' } }];\n}\n\nif (payload.exp < Math.floor(Date.now() / 1000)) {\n  return [{ json: { valid: false, reason: 'expired' } }];\n}\n\nconst jwks = $('Fetch JWKS').first().json;\nconst key = (jwks.keys || []).find(k => k.kid === header.kid);\nif (!key) return [{ json: { valid: false, reason: 'key_not_found' } }];\n\ntry {\n  const pubKey = createPublicKey({ key, format: 'jwk' });\n  const verifier = createVerify('RSA-SHA256');\n  verifier.update(`${headerB64}.${payloadB64}`);\n  const valid = verifier.verify(pubKey, Buffer.from(sigB64, 'base64url'));\n  return [{ json: { valid, userId: valid ? payload.sub : null, reason: valid ? null : 'invalid_signature' } }];\n} catch (e) {\n  return [{ json: { valid: false, reason: 'verify_error' } }];\n}"
      },
