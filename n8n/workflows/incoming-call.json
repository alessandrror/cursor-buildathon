      "parameters": {
        "jsCode": "// spec: §Respuesta exitosa — build TwiML based on decision\nconst { decision, rejectAction } = $('Evaluate Rules').first().json;\nconst agentUrl = process.env.ELEVENLABS_AGENT_WSS_URL || 'wss://placeholder.elevenlabs.io';\n\nlet twiml;\nif (decision === 'answer') {\n  twiml = `<Response><Connect><Stream url=\"${agentUrl}\"/></Connect></Response>`;\n} else {\n  if (rejectAction === 'busy') {\n    twiml = '<Response><Reject reason=\"busy\"/></Response>';\n  } else if (rejectAction === 'hangup') {\n    twiml = '<Response><Hangup/></Response>';\n  } else {\n    twiml = '<Response><Say language=\"es-MX\">Este número no está disponible en este momento.</Say><Hangup/></Response>';\n  }\n}\nreturn [{ json: { twiml } }];"
      },
