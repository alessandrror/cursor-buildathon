# =============================================================================
# GhostLine — Variables de entorno
# =============================================================================
# Copia este archivo a .env y completa los valores:
#   bun run env:setup
#
# =============================================================================

# --- Clerk (requerido) ---
# Dashboard: https://dashboard.clerk.com → tu app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rutas de autenticación
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/voz
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding/voz
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding/voz

# Webhook para sincronizar usuarios con Supabase (solo servidor)
# Dashboard: https://dashboard.clerk.com → Webhooks → Add endpoint
# URL del endpoint: https://tu-dominio.com/api/webhooks/clerk
# Eventos: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT template legacy (opcional). Si usas Third Party Auth nativo, déjalo comentado.
# CLERK_SUPABASE_JWT_TEMPLATE=supabase
#
# 1. Crea un proyecto en https://supabase.com/dashboard
# 2. Project URL:
#    Dashboard → Project Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
#
# 3. Publishable key (anon/public):
#    Dashboard → Project Settings → API Keys → Publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# Alias aceptado por compatibilidad:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# 4. Service role key (solo servidor — nunca expongas en el cliente):
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
#
# 5. Database URL (migraciones: bun run db:migrate)
#    Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
#
# Opcional: Session pooler (tiene prioridad sobre DATABASE_URL)
# DATABASE_POOLER_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# SUPABASE_DB_REGION=us-east-1
#
# 6. Integración Clerk ↔ Supabase:
#    El dashboard (servidor) usa Clerk userId + SUPABASE_SERVICE_ROLE_KEY — no requiere JWT bridge.
#    Opcional para RLS directo desde el browser: Third Party Auth en Supabase + template «supabase» en Clerk.

# --- ElevenLabs (Next.js: widget WebRTC + signed URL) ---
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxx
# Opcional si conectas por WSS directo (n8n Twilio usa esto en su propio entorno)
# ELEVENLABS_AGENT_WSS_URL=wss://api.elevenlabs.io/v1/convai/conversation?agent_id=agent_xxxxxxxx

# --- n8n Cloud (credenciales del workflow viven en n8n; opcional en Next.js) ---
# Ver integrations/n8n/README.md
# N8N_WEBHOOK_URL=https://your-org.app.n8n.cloud
# N8N_API_KEY=

# --- Pipeline telefónico (credenciales en n8n, no en Next.js) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# ELEVENLABS_WEBHOOK_SECRET=          # validación post-call en n8n
# OPENAI_API_KEY=                      # generate-summary en n8n
