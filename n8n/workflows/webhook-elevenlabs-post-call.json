    {
      "parameters": {
        "jsCode": "// spec: §Efectos colaterales — determinar outcome a partir de status y transcript\nconst extracted = $('Extract Fields').first().json;\nconst callRow = $('Lookup Call by SID').first().json;\n\nconst { status, transcript, durationSeconds, conversationId, agentId } = extracted;\n\nlet outcome;\nif (status === 'failed') {\n  outcome = 'agent_error';\n} else if (!transcript || transcript.length === 0) {\n  outcome = 'silent_hangup';\n} else {\n  outcome = 'completed';\n}\n\nreturn [{\n  json: {\n    outcome,\n    durationSeconds: durationSeconds ?? null,\n    endedAt: new Date().toISOString(),\n    callId: callRow.id,\n    userId: callRow.user_id,\n    conversationId,\n    transcript,\n    agentId\n  }\n}];"
      },
