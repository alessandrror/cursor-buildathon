    {
      "parameters": {
        "jsCode": "// spec: §Autenticación — Validar HMAC de ElevenLabs\n// Header format: ElevenLabs-Signature: t=<timestamp>,v0=<hex_signature>\n// Signed payload: '<timestamp>.<raw_body>'\nconst crypto = require('crypto');\n\nconst secret = $env['ELEVENLABS_WEBHOOK_SECRET'];\nconst sigHeader = $input.first().headers['elevenlabs-signature'] ?? '';\n\nconst parts = {};\nfor (const part of sigHeader.split(',')) {\n  const [k, v] = part.split('=');\n  parts[k] = v;\n}\n\nconst timestamp = parts['t'];\nconst v0 = parts['v0'];\n\nif (!timestamp || !v0) return [{ json: { valid: false } }];\n\n// Reject if older than 5 minutes\nconst age = Math.abs(Date.now() / 1000 - Number(timestamp));\nif (age > 300) return [{ json: { valid: false } }];\n\n// rawBody: true makes body a string; fall back to re-serialization if needed\nconst rawBody = typeof $input.first().body === 'string'\n  ? $input.first().body\n  : JSON.stringify($input.first().body);\n\nconst expected = crypto\n  .createHmac('sha256', secret)\n  .update(`${timestamp}.${rawBody}`)\n  .digest('hex');\n\n// ponytail: timingSafeEqual over === to prevent timing attacks\nconst valid = crypto.timingSafeEqual(Buffer.from(expected, 'hex'), Buffer.from(v0, 'hex'));\n\nconst body = typeof $input.first().body === 'string'\n  ? JSON.parse($input.first().body)\n  : $input.first().body;\n\nreturn [{ json: { valid, body } }];"
      },
      "id": "validate-hmac",
      "name": "Validate ElevenLabs HMAC",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true },
          "conditions": [
