        "jsCode": "// spec: §Validaciones — respond with same TwiML for duplicate CallSid\nconst call = $json;\nlet twiml;\nif (call.decision === 'answer') {\n  const agentUrl = process.env.ELEVENLABS_AGENT_WSS_URL || 'wss://placeholder.elevenlabs.io';\n  twiml = `<Response><Connect><Stream url=\"${agentUrl}\"/></Connect></Response>`;\n} else {\n  // Default reject for idempotent repeat\n  twiml = '<Response><Reject reason=\"busy\"/></Response>';\n}\nreturn [{ json: { twiml } }];"
